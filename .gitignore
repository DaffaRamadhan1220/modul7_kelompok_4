# This .gitignore file is for Visual Studio / .NET projects

## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/
*.vcxproj.filters

# Visual Studio Code
.vscode/

# Rider
.idea/

# Backup & report files from converting an old project file
*.bak
*.cache
*.cachefile
*.log
*.tlog
*.rpt
*.rptproj.bak
*_i.c
*_p.c
*_i.h
*.ilk
*.meta
*.obj
*.pch
*.pdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_log.xml
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# Visual C++ cache files
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Trace Logging files
*.eTL
*.tlf

# Test files
*.testsettings
*.testlog
*.trx
*.trxlog

# Fakes - Fakes assemblies
FakesAssemblies/

# DotCover
*.dotCover

# NCrunch
*.ncrunch*
.*crunch*.local.xml

# MightyMoose
*.mm.*
AutoTest.Net/

# Web load test
*.webtest

# Windows Store app project directories
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_pkg/
*.appx
*.appxbundle
*.appupload

# Publish Web Output
*.Publish.xml
*.pubxml
*.pubxml.user
*.publishproj

# NuGet Packages
*.nupkg
*.snupkg
packages/
!**/packages/build/
*.nupkg.metadata
*.nupkg.props
*.nupkg.targets
*.nuspec
*.nuspec.user
*.nuspec.tmp

# NuGet Symbol Packages
*.snupkg

# NuGet Package Manager Lock file
packages.lock.json

# Paket dependency manager
.paket/paket.exe
paket-files/

# FAKE - F# Make
.fake/

# CodeRush
.cr/

# Python Tools for Visual Studio (PTVS)
__pycache__/
*.pyc

# Cake build tool
/tools/Cake/
/tools/Addins/

# JetBrains Rider
.idea/
*.sln.iml

# SonarQube
.sonarqube/
out/

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Local History for Visual Studio Code
.history/

# Windows image file caches
Thumbs.db
ehthumbs.db
*.DStored
*.Spotlight-V100
*.Trashes
*.Trash

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Mac OS X files
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
*.AppleDB
*.AppleDesktop
*.apdisk

# Linux files
*~
.directory
*.swp
*.swo
*.swn

# Build results of Visual Studio
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bld/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml

# Build Results of an Azure Pipelines
[Tt]est[Rr]esults/
[Bb]uild[Pp]ipeline/

# Visual C++ db files
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Ignore node_modules (if any)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore rider folders
.idea/
*.sln.iml

# Ignore any .json files that might be user-specific (optional - comment if you want to keep JSON files)
# *.user.json

# Ignore log files
*.log
*.logs

# Ignore runtime files
*.runtimeconfig.json
*.deps.json

# Ignore compiled output
*.exe
*.dll
*.so
*.dylib

# Ignore generated documentation
docs/_build/
docs/api/

# Ignore benchmarking results
BenchmarkDotNet.Artifacts/